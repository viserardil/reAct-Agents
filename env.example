# ---------------------------------------------------------------------------
# SAĞLAYICI-BAĞIMSIZ kullanım: aşağıdaki LLM_* değişkenleri, ayarlanırsa HF_*'ın
# yerine geçer. Herhangi bir sağlayıcının anahtarını verip 3 satırı doldurman
# yeter (çoğu sağlayıcı OpenAI-uyumlu bir endpoint sunar).
#
# Örnek — Gemini:
#   LLM_API_KEY=<gemini_key>
#   LLM_MODEL=gemini-2.5-flash
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Örnek — OpenAI:
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
# Örnek — Groq:
#   LLM_API_KEY=<groq_key>
#   LLM_MODEL=llama-3.3-70b-versatile
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#
# Sağlayıcı structured output'ta json_schema desteklemiyorsa:
#   LLM_STRUCTURED_METHOD=function_calling   (ya da json_mode)
# Native entegrasyon istersen (paketi kur): LLM_PROVIDER=google_genai vb.
# ---------------------------------------------------------------------------

TAVILY_API_KEY=